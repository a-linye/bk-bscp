    "definitions": {
        "cc.ResourceLimit": {
            "type": "object",
            "properties": {
                "appConfigCnt": {
                    "description": "AppConfigCnt 单个app下允许创建的配置数（模版+非模版），默认为2000",
                    "type": "integer"
                },
                "maxFileSize": {
                    "description": "MaxFileSize 配置文件大小上限，单位 MB，默认为200MB",
                    "type": "integer"
                },
                "maxUploadContentLength": {
                    "description": "MaxUploadContentLength 最大内容长度",
                    "type": "integer"
                },
                "tmplSetTmplCnt": {
                    "description": "TmplSetTmplCnt 单个模版套餐下允许创建的模版数，默认为2000",
                    "type": "integer"
                }
            }
        },
        "repository.ObjectMetadata": {
            "type": "object",
            "properties": {
                "byte_size": {
                    "type": "integer"
                },
                "md5": {
                    "type": "string"
                },
                "sha256": {
                    "type": "string"
                }
            }
        },
        "rest.OKResponse": {
            "type": "object",
            "properties": {
                "data": {}
            }
        },
        "service.DownloadURLResponse": {
            "type": "object",
            "properties": {
                "download_url": {
                    "type": "string"
                },
                "expire_seconds": {
                    "type": "integer"
                }
            }
        },
        "service.FeatureFlags": {
            "type": "object",
            "properties": {
                "BIZ_VIEW": {
                    "description": "BizView 是否开启业务体验",
                    "type": "boolean"
                },
                "ENABLE_TENANT_MODE": {
                    "description": "EnableTenantMode 是否开启租户模式",
                    "type": "boolean"
                },
                "PROCESS_CONFIG_VIEW": {
                    "description": "ProcessConfigView 进程与配置管理是否可见",
                    "type": "boolean"
                },
                "RESOURCE_LIMIT": {
                    "description": "ResourceLimit 业务资源限制",
                    "allOf": [
                        {
                            "$ref": "#/definitions/cc.ResourceLimit"
                        }
                    ]
                },
                "TENANT_MODE": {
                    "description": "TenantMode 租户模式",
                    "type": "string"
                },
                "TRPC_GO_PLUGIN": {
                    "description": "TrpcGoPlugin trpc go plugin",
                    "allOf": [
                        {
                            "$ref": "#/definitions/service.TrpcGoPlugin"
                        }
                    ]
                }
            }
        },
        "service.TrpcGoPlugin": {
            "type": "object",
            "properties": {
                "bscp_module_domain": {
                    "type": "string"
                },
                "enable": {
                    "type": "boolean"
                },
                "module_domain": {
                    "type": "string"
                }
            }
        }
