        "/api/v1/inner/feature_flags": {
            "get": {
                "description": "根据业务ID（biz）获取该业务下的特性开关以及资源配额限制。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统相关"
                ],
                "summary": "获取特性开关及资源限制配置",
                "operationId": "get_feature_flags",
                "parameters": [
                    {
                        "type": "string",
                        "description": "业务ID/业务标识",
                        "name": "biz",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功获取特性开关列表",
                        "schema": {
